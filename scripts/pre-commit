#!/usr/bin/env bash
# =================================================================
# security-writeups pre-commit hook
# Purpose: Block password leaks before they reach GitHub
# Install: copy to .git/hooks/pre-commit and chmod +x
# =================================================================

set -euo pipefail

# Color codes
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

VIOLATIONS=0
WARNINGS=0

echo "🔍 Pre-commit security scan..."

# ----------------------------------------------------------------
# 1. Check for password-like high-entropy strings in staged files
# ----------------------------------------------------------------
# Bandit passwords are typically 32 chars, alphanumeric, no obvious dictionary words
# Pattern: 30+ consecutive [a-zA-Z0-9] not preceded by common safe contexts

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(md|txt|sh|ps1)$' || true)

if [ -z "$STAGED_FILES" ]; then
    echo "  No relevant staged files. Skipping content scan."
    exit 0
fi

for file in $STAGED_FILES; do
    # Skip if file doesn't exist (deleted)
    [ -f "$file" ] || continue

    # Get staged content only (not working tree)
    STAGED_CONTENT=$(git show :"$file" 2>/dev/null || cat "$file")

    # Pattern 1: High-entropy 30+ char alphanumeric strings
    # Whitelist (case-insensitive): masked, REDACTED, fingerprints, hashes, public keys, etc.
    # PGP fingerprints, SHA hashes, commit hashes, public SSH keys are SAFE to commit.
    SUSPECT_LINES=$(echo "$STAGED_CONTENT" | grep -nE '[a-zA-Z0-9]{30,}' | \
                    grep -ivE '(masked|redacted|example|placeholder|<.*>|sha256|sha-256|sha512|fingerprint|hash|commit|uuid|public[[:space:]]+key|key[[:space:]]+id|ssh-ed25519|ssh-rsa|aaaa[a-z]{4})' || true)

    if [ -n "$SUSPECT_LINES" ]; then
        echo -e "${RED}❌ SUSPECT PASSWORD-LIKE STRING in $file:${NC}"
        echo "$SUSPECT_LINES" | head -5
        echo ""
        VIOLATIONS=$((VIOLATIONS + 1))
    fi

    # Pattern 2: SSH private key headers
    # NOTE: optional group uses `( )?`, NOT `( |)` — BSD grep (macOS) rejects
    # empty alternation branches with "empty (sub)expression" and the check
    # would silently fail open.
    if echo "$STAGED_CONTENT" | grep -qE 'BEGIN (RSA |DSA |EC |OPENSSH )?PRIVATE KEY'; then
        echo -e "${RED}❌ PRIVATE KEY DETECTED in $file${NC}"
        VIOLATIONS=$((VIOLATIONS + 1))
    fi

    # Pattern 3: AWS / API key patterns
    if echo "$STAGED_CONTENT" | grep -qE '(AKIA[0-9A-Z]{16}|sk_live_[0-9a-zA-Z]{24,})'; then
        echo -e "${RED}❌ CLOUD/API KEY PATTERN in $file${NC}"
        VIOLATIONS=$((VIOLATIONS + 1))
    fi

    # Pattern 4: Explicit "Password:" followed by plaintext (warning, not block)
    if echo "$STAGED_CONTENT" | grep -iE 'password\s*[:=]\s*[a-zA-Z0-9]{8,}' | grep -vE '(masked|REDACTED|<|example)' >/dev/null; then
        echo -e "${YELLOW}⚠️  Possible plaintext password in $file (review manually)${NC}"
        WARNINGS=$((WARNINGS + 1))
    fi
done

# ----------------------------------------------------------------
# 2. Check filenames being committed
# ----------------------------------------------------------------
FORBIDDEN_NAMES=$(echo "$STAGED_FILES" | grep -iE '(password|secret|credential|\.env)' || true)

if [ -n "$FORBIDDEN_NAMES" ]; then
    echo -e "${RED}❌ FORBIDDEN FILENAME being committed:${NC}"
    echo "$FORBIDDEN_NAMES"
    VIOLATIONS=$((VIOLATIONS + 1))
fi

# ----------------------------------------------------------------
# 3. Report
# ----------------------------------------------------------------
echo ""
if [ $VIOLATIONS -gt 0 ]; then
    echo -e "${RED}========================================${NC}"
    echo -e "${RED}❌ COMMIT BLOCKED: $VIOLATIONS violation(s)${NC}"
    echo -e "${RED}========================================${NC}"
    echo ""
    echo "Options:"
    echo "  1. Mask the password: replace with '<password masked>' or '[REDACTED]'"
    echo "  2. If false positive, bypass with: git commit --no-verify (NOT RECOMMENDED)"
    echo "  3. If filename forbidden, add to .gitignore and remove from staging:"
    echo "     git rm --cached <file>"
    exit 1
fi

if [ $WARNINGS -gt 0 ]; then
    echo -e "${YELLOW}⚠️  $WARNINGS warning(s) — review before pushing${NC}"
fi

echo -e "${GREEN}✅ Security scan passed${NC}"
exit 0
